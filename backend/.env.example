# =====================================================================
# 🌐 AI Gateway & Backend Environment Configuration Example (.env.example)
# =====================================================================

# Copy file này thành .env khi triển khai trên máy mới:
# cp .env.example .env

# 1. Google Gemini AI Engine API Key (https://aistudio.google.com/)
GEMINI_API_KEY="demo_api_key_portfolio_2026"
OPENROUTER_MODEL="google/gemma-4-31b-it:free"

# 2. Security & JWT Authentication
JWT_SECRET_KEY="your_secure_jwt_secret_key_placeholder"
JWT_ALGORITHM="HS256"

# 3. Database Connection (Microsoft SQL Server qua Docker trên cổng 1111)
MSSQL_SA_PASSWORD="YourSecurePasswordHere2026!"
DATABASE_URL="mssql+pymssql://sa:YourSecurePasswordHere2026!@localhost:1111/LanguageAppDB"

# 4. Redis Cache Engine (Cổng tăng tiếp theo là 1113)
REDIS_URL="redis://localhost:1113/0"
CACHE_TTL_SECONDS=3600

# 5. Server Settings (Cổng tăng từ 1111 -> 1112 cho AI Gateway)
APP_NAME="Language Learning & IELTS AI Gateway"
APP_ENV="development"
PORT=1112

# 6. Anime VA Voice Engine Service (Style-Bert-VITS2 / GPT-SoVITS trên cổng 1114)
VOICE_ENGINE_URL="http://localhost:1114"
DEFAULT_SPEAKER_ID="sensei_va_01"


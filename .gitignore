# =====================================================================
# 🔒 Git Ignore Configuration (Preventing Secrets & Build Artifacts Leak)
# =====================================================================

# --- Secrets & Environment Variables ---
.env
.env.local
.env.*.local
!.env.example
*.key
*.pem
secrets.json

# --- Database & Cache Local Volumes ---
*.db
*.sqlite
*.sqlite3
app.db
backend/app.db
mssql_data/
redis_data/
*.log

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.venv/
.venv3/
venv/
ENV/
env/
.mypy_cache/
.ruff_cache/

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
mobile/build/
*.flutter-plugins*
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
android/.gradle/
android/app/build/
android/local.properties
android/*.keystore
android/*.jks

# --- IDE & OS ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
.DS_Store
Thumbs.db